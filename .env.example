COMPOSE_PROJECT_NAME=interview-agent
FRONTEND_PORT=3000
BACKEND_PORT=4000
POSTGRES_PORT=5432
POSTGRES_DB=interview_agent
POSTGRES_USER=interview_agent
POSTGRES_PASSWORD=interview_agent_dev
DATABASE_URL=postgresql://interview_agent:interview_agent_dev@postgres:5432/interview_agent
NEXT_PUBLIC_API_BASE_URL=http://localhost:4000
VITE_API_BASE_URL=http://localhost:4000

OPENAI_API_KEY=
# Default LLM model for agentic generation, evaluation, and extraction
OPENAI_MODEL=gpt-5.5
PERPLEXITY_API_KEY=
PERPLEXITY_BASE_URL=https://api.perplexity.ai
PERPLEXITY_MODEL=sonar
NEXT_PUBLIC_APP_DEFAULT_LOCALE=en
NEXT_PUBLIC_SITE_URL=http://localhost:3000
# Supabase auth contract for v1:
# - email auth is enabled for direct registration and login flows
# - Google OAuth is enabled in Supabase and must redirect back to NEXT_PUBLIC_SITE_URL
# Supabase public client keys (recommended canonical keys for this repo)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Legacy compatibility fallback keys
SUPABASE_URL=
SUPABASE_ANON_KEY=
# Server-only key for privileged jobs, never expose in the browser bundle
SUPABASE_SERVICE_ROLE_KEY=
# Optional Vite aliases (only needed if you explicitly run pure Vite mode)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
ELEVENLABS_API_KEY=
ELEVENLABS_BASE_URL=https://api.elevenlabs.io
ELEVENLABS_VOICE_ID=lZORFNDokoBmfd0S06vf
NEXT_PUBLIC_ELEVENLABS_RELAY_PATH=/api/elevenlabs/interviewer-speech
NEXT_PUBLIC_ELEVENLABS_OUTPUT_FORMAT=mp3_44100_128
NEXT_PUBLIC_ELEVENLABS_VOICE_ID_EN=lZORFNDokoBmfd0S06vf
NEXT_PUBLIC_ELEVENLABS_VOICE_ID_JA=lZORFNDokoBmfd0S06vf
# Optional end-to-end auth test credentials for real Supabase-backed Playwright runs
E2E_ENABLE_REAL_GOOGLE_OAUTH=false
E2E_SUPABASE_EMPLOYER_EMAIL=
E2E_SUPABASE_EMPLOYER_PASSWORD=
E2E_SUPABASE_JOB_SEEKER_EMAIL=
E2E_SUPABASE_JOB_SEEKER_PASSWORD=
E2E_SUPABASE_SIGNUP_JOB_SEEKER_EMAIL=
E2E_SUPABASE_SIGNUP_JOB_SEEKER_PASSWORD=
